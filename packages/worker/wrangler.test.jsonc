{
  "name": "agentpostoffice-test",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-10",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "MAIL_DOMAIN": "mail.example.com",
    "MAX_INBOUND_BYTES": "10485760",
    "BODY_EXCERPT_BYTES": "8192",
    "DLQ_NAME": "agentpostoffice-dlq-test"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "agentpostoffice-test",
      "database_id": "00000000-0000-0000-0000-000000000001",
      "migrations_dir": "migrations"
    }
  ],
  "r2_buckets": [{ "binding": "MAIL_BUCKET", "bucket_name": "agentpostoffice-mail-test" }],
  "queues": {
    "producers": [{ "binding": "MAIL_QUEUE", "queue": "agentpostoffice-mail-test" }]
  },
  "send_email": [{ "name": "EMAIL" }]
}
